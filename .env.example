# ==============================================================================
# GTA-Claw Environment Variables
# Copy this file to .env and fill in the values
# ==============================================================================

# ---- Auth (choose one mode) ----

# Mode A: Personal Access Token (PAT)
# GitHub token with Copilot-related access
GITHUB_TOKEN=

# Mode B: Device Flow (recommended, no domain needed)
# Set DEVICE_FLOW_ENABLED=true and provide your GitHub OAuth App Client ID.
# Users authorize via https://github.com/login/device with a one-time code.
# DEVICE_FLOW_ENABLED=true
# GITHUB_CLIENT_ID=

# ---- Required ----

# Azure Bot Service credentials (from Azure Portal → Bot registration)
MicrosoftAppId=
MicrosoftAppPassword=

# URL to the role configuration JSON
# Format: { "content": "You are a...", "model": "claude-opus-4.6" }
AGENT_ROLE_URL=

# Comma-separated URLs to skill JSON modules
ENABLED_SKILLS=

# ---- Optional ----

# Default AI model (overridden by role config "model" field)
COPILOT_MODEL=gpt-4o

# Domain for Caddy HTTPS (use "localhost" for local dev with self-signed cert)
DOMAIN=localhost

# Server port (internal, Caddy proxies from 443)
# PORT=3978

# Logging level: trace, debug, info, warn, error, fatal
# LOG_LEVEL=info

# Session management
# MAX_SESSIONS=100
# SESSION_TTL_MS=3600000

# Skill execution limits
# SKILL_EXEC_TIMEOUT_MS=30000
# SDK_REQUEST_TIMEOUT_MS=120000

# Rate limit for /api/messages (requests per minute per IP)
# RATE_LIMIT_PER_MIN=30

# Domain whitelist for skill HTTP bridges (comma-separated, empty = allow all)
# ALLOWED_SKILL_DOMAINS=api.example.com,data.example.com

# Trust x-forwarded-for header from upstream proxy (set true only behind trusted proxy)
# TRUST_PROXY=false

# Auto-update SDK/CLI on startup
# AUTO_UPDATE=false

# Admin endpoint protection token
# ADMIN_TOKEN=

# HTTP proxy for outbound requests (GitHub API, skill fetches, etc.)
# Useful when deployed in regions with restricted internet access.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# ---- Channel Switches ----

# Teams Bot Framework endpoint (/api/messages)
# ENABLE_TEAMS=false

# Telegram polling mode (no public webhook required)
# ENABLE_TELEGRAM=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_POLL_INTERVAL_MS=2000

# Discord gateway mode (no public webhook required)
# ENABLE_DISCORD=false
# DISCORD_BOT_TOKEN=
# DISCORD_GATEWAY_URL=wss://gateway.discord.gg/?v=10&encoding=json
# DISCORD_GATEWAY_INTENTS=33281

# WhatsApp Cloud API webhook mode (public callback usually required)
# ENABLE_WHATSAPP=false
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_PATH=/whatsapp/webhook
