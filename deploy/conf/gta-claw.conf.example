# ==============================================================================
# GTA-Claw 部署配置文件
# 复制本文件为 gta-claw.conf 并填写实际值
# 用法: ./run.sh --config conf/gta-claw.conf
# ==============================================================================

# ---- 鉴权 (二选一) ----

# 方案 A: Personal Access Token
GITHUB_TOKEN=

# 方案 B: OAuth 网页授权 (企业推荐)
OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AUTH_BASE_URL=
OAUTH_CALLBACK_PATH=/auth/callback
OAUTH_SCOPE=copilot

# ---- 必填项 ----

# Azure Bot Service 凭据 (Azure Portal → Bot 注册)
MicrosoftAppId=
MicrosoftAppPassword=

# Role 配置 JSON 的 URL
# 格式: { "content": "You are a...", "model": "gpt-4o" }
AGENT_ROLE_URL=

# Skill 模块 URL (多个用逗号分隔)
ENABLED_SKILLS=

# ---- 可选项 (有默认值) ----

# Docker 镜像名称 (Docker Hub)
DOCKER_IMAGE=gtastudio/gta-claw:latest

# AI 模型 (会被 role config 中的 model 字段覆盖)
COPILOT_MODEL=gpt-4o

# 域名 (反向代理对外域名, 本地测试用 localhost)
DOMAIN=localhost

# 日志级别: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# 最大会话数
MAX_SESSIONS=100

# 会话过期时间 (毫秒)
SESSION_TTL_MS=3600000

# Skill 执行超时 (毫秒)
SKILL_EXEC_TIMEOUT_MS=30000

# SDK 请求超时 (毫秒)
SDK_REQUEST_TIMEOUT_MS=120000

# 速率限制 (每 IP 每分钟请求数, 仅 /api/messages)
RATE_LIMIT_PER_MIN=30

# Skill HTTP 请求域名白名单 (逗号分隔, 留空=不限制)
ALLOWED_SKILL_DOMAINS=

# 信任上游代理的 x-forwarded-for 头 (仅在受信代理后面设 true)
TRUST_PROXY=false

# 自动更新 SDK/CLI
AUTO_UPDATE=false

# Admin API 令牌 (留空则禁用 /admin/reload 端点)
ADMIN_TOKEN=

# ---- 通道开关 ----

# Teams (Bot Framework)
ENABLE_TEAMS=true

# Telegram (Polling, 内网可用)
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_INTERVAL_MS=2000

# Discord (Gateway, 内网可用)
ENABLE_DISCORD=false
DISCORD_BOT_TOKEN=
DISCORD_GATEWAY_URL=wss://gateway.discord.gg/?v=10&encoding=json
DISCORD_GATEWAY_INTENTS=33281

# WhatsApp (Webhook, 通常需要公网回调)
ENABLE_WHATSAPP=false
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_PATH=/whatsapp/webhook
